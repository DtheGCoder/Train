// Fitness-Tracker — Datenmodell
// SQLite via Prisma. Enum-artige Felder werden als String gespeichert,
// da SQLite keine nativen Enums kennt.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model MuscleGroup {
  id         String     @id @default(cuid())
  slug       String     @unique
  nameDe     String
  nameEn     String
  bodyRegion String // z.B. "Oberkörper", "Unterkörper", "Rumpf"
  exercises  Exercise[]
}

model Equipment {
  id        String     @id @default(cuid())
  slug      String     @unique
  nameDe    String
  nameEn    String
  exercises Exercise[]
}

model Exercise {
  id                String   @id @default(cuid())
  nameDe            String
  nameEn            String
  primaryMuscle     MuscleGroup @relation(fields: [primaryMuscleId], references: [id])
  primaryMuscleId   String
  secondaryMuscles  String   @default("") // Komma-separierte Muskel-Slugs
  equipment         Equipment? @relation(fields: [equipmentId], references: [id])
  equipmentId       String?
  category          String   @default("strength") // strength, cardio, stretching
  mechanic          String   @default("isolation") // compound, isolation
  forceType         String   @default("push") // push, pull, static
  // Wie wird die Übung getrackt: "reps" (Wiederholungen) oder "time" (Sekunden,
  // z. B. Plank, Wandsitz, Cardio).
  trackingType      String   @default("reps")
  instructions      String   @default("")
  isCustom          Boolean  @default(false)
  createdAt         DateTime @default(now())

  // Pro-Nutzer-Eigentum (jeder hat seinen eigenen Übungskatalog).
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String?

  routineExercises  RoutineExercise[]
  workoutExercises  WorkoutExercise[]
  personalRecords   PersonalRecord[]

  @@index([primaryMuscleId])
  @@index([userId])
}

model Routine {
  id          String            @id @default(cuid())
  name        String
  description String            @default("")
  color       String            @default("#6366f1")
  isPreset    Boolean           @default(false)
  // Von Nutzer freigegebene, selbst erstellte Vorlage (Community). Nie für Presets.
  isPublic    Boolean           @default(false)
  // Vorlagen-Metadaten (für Filter, Beschreibung & Coach-Empfehlung).
  goal        String            @default("") // strength, hypertrophy, endurance, general
  level       String            @default("") // beginner, intermediate, advanced
  location    String            @default("") // gym, home, both
  category    String            @default("") // Split-Typ, z. B. "Push/Pull/Legs", "Ganzkörper"
  benefits    String            @default("") // Wofür ist der Plan gut / was wird trainiert
  // Wurde diese Routine als Tag eines Coach-Programms erzeugt? Dann nicht in der
  // normalen "Deine Pläne"-Liste anzeigen (erscheint in der Programm-Übersicht).
  fromProgram Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String?
  exercises   RoutineExercise[]
  workouts    Workout[]

  @@index([userId])
  @@index([isPublic])
}

// Ein mehrtägiges Coach-Programm: eine geordnete Folge von Trainingstagen, die
// nacheinander absolviert werden. Wird beim Aktivieren aus einer kuratierten
// Vorlage (program-data.ts) für den Nutzer instanziiert.
model Program {
  id          String       @id @default(cuid())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  key         String // Schlüssel der kuratierten Vorlage (z. B. "ppl-6")
  name        String
  description String       @default("")
  goal        String       @default("")
  level       String       @default("")
  location    String       @default("")
  daysPerWeek Int          @default(3)
  // Trainingstage der Woche als CSV (ISO: 1=Mo … 7=So), z. B. "1,3,5".
  weekdays    String       @default("")
  cursor      Int          @default(0) // Index des nächsten Tages
  cycles      Int          @default(0) // abgeschlossene Durchläufe
  active      Boolean      @default(true)
  // Coach-Anpassungen: Protokoll automatischer Änderungen (JSON-Array) und
  // Durchlauf, in dem zuletzt entlastet (Deload) wurde.
  coachLogJson    String   @default("[]")
  lastDeloadCycle Int      @default(0)
  startedAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  days        ProgramDay[]

  @@index([userId])
}

model ProgramDay {
  id        String  @id @default(cuid())
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId String
  position  Int     @default(0)
  label     String // z. B. "Tag 1 – Push"
  focus     String  @default("") // kurze Beschreibung des Tages
  routineId String // verweist auf die für diesen Tag erzeugte Routine

  @@index([programId])
}

model RoutineExercise {
  id            String   @id @default(cuid())
  routine       Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  routineId     String
  exercise      Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId    String
  position      Int      @default(0)
  targetSets    Int      @default(3)
  targetReps    Int      @default(10)
  targetWeight  Float    @default(0) // geplantes Arbeitsgewicht (kg); 0 = offen
  // Optionale individuelle Sätze als JSON: [{reps,weight}]. Leer = uniform aus
  // targetSets/targetReps/targetWeight.
  setsJson      String   @default("")
  targetRestSec Int      @default(90)
  notes         String   @default("")
  supersetGroup Int? // Übungen mit gleicher Gruppe = Supersatz

  @@index([routineId])
}

model Workout {
  id          String            @id @default(cuid())
  name        String            @default("Workout")
  routine     Routine?          @relation(fields: [routineId], references: [id])
  routineId   String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String?
  startedAt   DateTime          @default(now())
  finishedAt  DateTime?
  notes       String            @default("")
  totalVolume Float             @default(0)
  exercises   WorkoutExercise[]

  @@index([startedAt])
  @@index([userId])
}

model WorkoutExercise {
  id            String      @id @default(cuid())
  workout       Workout     @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  workoutId     String
  exercise      Exercise    @relation(fields: [exerciseId], references: [id])
  exerciseId    String
  position      Int         @default(0)
  notes         String      @default("")
  supersetGroup Int?
  sets          WorkoutSet[]

  @@index([workoutId])
}

model WorkoutSet {
  id                String          @id @default(cuid())
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  workoutExerciseId String
  setNumber         Int             @default(1)
  weight            Float           @default(0)
  reps              Int             @default(0)
  durationSec       Int             @default(0) // für Zeit-Übungen (Plank etc.)
  rpe               Float? // 1-10, optional
  setType           String          @default("normal") // warmup, normal, dropset, failure
  isCompleted       Boolean         @default(false)
  restSec           Int             @default(0)

  @@index([workoutExerciseId])
}

model PersonalRecord {
  id         String   @id @default(cuid())
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId String
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String?
  recordType String // "1rm", "volume", "maxReps", "maxWeight"
  value      Float
  achievedAt DateTime @default(now())

  @@index([exerciseId, recordType])
  @@index([userId])
}

model User {
  id           String    @id @default(cuid())
  username     String    @unique // Login-Name (klein geschrieben)
  displayName  String? // optionaler Anzeigename; Fallback ist username
  avatar       String? // optionales Profilbild als data-URL (klein skaliert)
  passwordHash String
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  sessions     Session[]

  // Pro-Nutzer-Daten (sauber getrennt).
  exercises       Exercise[]
  routines        Routine[]
  workouts        Workout[]
  personalRecords PersonalRecord[]
  programs        Program[]
  nutritionDays   NutritionDay[]
  settings        Settings?
}

// Ernährungs-Tagesprotokoll: abgehakte Plan-Items + manuelle Extras + Wasser.
model NutritionDay {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  date         String // YYYY-MM-DD
  checkedJson  String   @default("[]") // abgehakte Plan-Item-Keys
  extraKcal    Float    @default(0)
  extraProtein Float    @default(0)
  extraCarbs   Float    @default(0)
  extraFat     Float    @default(0)
  waterMl      Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Settings {
  id    String @id @default(cuid())
  // Pro-Nutzer-Einstellungen (1:1). Früher ein globaler Singleton.
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String? @unique
  units String @default("kg") // kg, lbs
  theme String @default("dark") // dark, light

  // Coach-Profil / Persönlichkeitsdaten
  goal         String @default("hypertrophy") // strength, hypertrophy, endurance
  experience   String @default("intermediate") // beginner, intermediate, advanced
  coachStyle   String @default("balanced") // cautious, balanced, aggressive
  sex          String @default("") // m, f, ""
  birthYear    Int?
  bodyweightKg Float?
  heightCm     Float?

  // Erweiterte Coach-Daten (mehr Personalisierung)
  trainingDaysPerWeek Int? // 1-7, beeinflusst Volumen-/Erholungs-Hinweise
  limitations         String @default("") // Verletzungen/Einschränkungen (Freitext)
  availableEquipment  String @default("") // CSV Equipment-Slugs; "" = alles verfügbar
  preferredRepStyle   String @default("auto") // auto, low, high — feinjustiert Wdh.

  // Gelesene Neuigkeiten (Postfach) als JSON-Array von News-IDs.
  readNewsJson        String @default("[]")
}
